<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <!-- Title of the consent dialog explaining how Gboard uses screen context. [CHAR LIMIT=50] -->
    <string name="super_icon_consent_title">How Gboard uses screen context</string>

    <!-- First paragraph of the consent dialog body text. Explains data processing. [CHAR LIMIT=NONE] -->
    <string name="super_icon_consent_body_1">To provide more relevant writing suggestions, writing tools take a snapshot of your screen only at the time of use. This content, including any communications you view or receive, is processed in a secure, isolated environment on your device or in the cloud, where it\'s not shared with Google or any app.</string>

    <!-- Second paragraph of the consent dialog body text. Explains how to turn off the feature. [CHAR LIMIT=NONE] -->
    <string name="super_icon_consent_body_2">You can turn this feature off at any time.</string>

    <!-- Label for the button to decline consent. [CHAR LIMIT=20] -->
    <string name="super_icon_consent_no_button">No, thanks</string>

    <!-- Label for the button to accept consent. [CHAR LIMIT=20] -->
    <string name="super_icon_consent_yes_button">OK</string>

    <!-- Content description for the Writing Tools icon in the consent dialog. Spoken by screen readers. [CHAR LIMIT=30] -->
    <string name="super_icon_content_description">Writing tools</string>
</resources>
